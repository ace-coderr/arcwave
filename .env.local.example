# ─── ArcWave Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite for local development (auto-creates dev.db in your project folder)
DATABASE_URL="file:./dev.db"

# For production on Vercel, use a hosted Postgres (e.g. Neon.tech free tier):
# DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Required for mobile wallet connections (MetaMask Mobile, Rainbow, etc.)
# Get your free Project ID at: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="f56a7305b7c1c0164f2c8222a5bda745"

# ── Circle API (optional — for future Circle Wallets integration) ─────────────
# Get your API key at: https://console.circle.com
# CIRCLE_API_KEY="your_circle_api_key_here"
# CIRCLE_ENTITY_SECRET="your_entity_secret_here"

# ── App URL ──────────────────────────────────────────────────────────────────
# Used to generate shareable payment link URLs.
# Leave blank for local dev (defaults to http://localhost:3000)
# NEXT_PUBLIC_APP_URL="https://your-arcwave.vercel.app"
