generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model PaymentLink {
  id                String    @id @default(cuid())
  title             String
  description       String?
  amount            String
  recipientAddress  String
  stealthAddress    String?
  stealthPrivateKey String?
  status            String    @default("ACTIVE")
  expiresAt         DateTime?
  txHash            String?
  forwardTxHash     String?
  paidBy            String?
  paidAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model EscrowLink {
  id                  String          @id @default(cuid())
  title               String
  description         String?
  amount              String
  sellerAddress       String
  sellerContact       String?
  buyerAddress        String?
  stealthAddress      String
  stealthPrivateKey   String
  status              String          @default("ACTIVE")
  txHash              String?
  releaseTxHash       String?
  feeTxHash           String?
  paidAt              DateTime?
  deliveryDays        Int?            // seller-set expected delivery window in days
  deliveryDeadline    DateTime?       // paidAt + deliveryDays
  releaseDeadline     DateTime?       // deliveryDeadline + 7 days (auto-release)
  confirmedAt         DateTime?
  disputedAt          DateTime?
  disputeReason       String?
  disputeDeadline     DateTime?
  sellerRespondedAt   DateTime?
  buyerLastMessageAt  DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  messages            EscrowMessage[]
}

model EscrowMessage {
  id            String     @id @default(cuid())
  escrowId      String
  escrow        EscrowLink @relation(fields: [escrowId], references: [id])
  sender        String
  senderAddress String?
  message       String
  createdAt     DateTime   @default(now())
}

model X402Payment {
  id        String   @id @default(cuid())
  txHash    String   @unique
  payer     String
  payTo     String
  amount    String
  network   String
  resource  String
  nonce     String
  settledAt DateTime @default(now())
  createdAt DateTime @default(now())
}