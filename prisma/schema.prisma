generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model PaymentLink {
  id                   String    @id @default(cuid())
  title                String
  description          String?
  amount               String
  recipientAddress     String    // Real wallet — never shown to payers
  stealthAddress       String?   // Temp wallet shown to payers
  stealthPrivateKey    String?   // Encrypted private key for forwarding
  forwardTxHash        String?   // Tx hash of the forwarding transaction
  status               String    @default("ACTIVE")
  txHash               String?   // Payer's tx hash
  paidBy               String?
  paidAt               DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}
