// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model PaymentLink {
  id                String    @id @default(cuid())
  title             String
  description       String?
  amount            String
  recipientAddress  String
  stealthAddress    String?
  stealthPrivateKey String?
  status            String    @default("ACTIVE")
  expiresAt         DateTime?
  txHash            String?
  forwardTxHash     String?
  paidBy            String?
  paidAt            DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model EscrowLink {
  id                  String          @id @default(cuid())
  title               String
  description         String?
  amount              String
  sellerAddress       String
  sellerContact       String?
  buyerAddress        String?
  stealthAddress      String
  stealthPrivateKey   String
  status              String          @default("ACTIVE")
  // ACTIVE → HOLDING → CONFIRMED/DISPUTED → MEDIATION/RELEASED → CANCELLED
  txHash              String?
  releaseTxHash       String?
  feeTxHash           String?
  paidAt              DateTime?
  releaseDeadline     DateTime?
  confirmedAt         DateTime?
  disputedAt          DateTime?
  disputeReason       String?
  disputeDeadline     DateTime?       // 48hrs after dispute raised
  sellerRespondedAt   DateTime?       // when seller submits their side
  buyerLastMessageAt  DateTime?       // last buyer message after dispute
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  messages            EscrowMessage[]
}

// Mediation message thread
model EscrowMessage {
  id            String     @id @default(cuid())
  escrowId      String
  escrow        EscrowLink @relation(fields: [escrowId], references: [id])
  sender        String     // "BUYER" | "SELLER" | "ADMIN" | "SYSTEM"
  senderAddress String?
  message       String
  createdAt     DateTime   @default(now())
}
